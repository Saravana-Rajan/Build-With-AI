# ─────────────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# Google Cloud
GCP_PROJECT_ID=gemini-enterprise-475109
GCP_REGION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# Vertex AI / Gemini
VERTEX_LOCATION=asia-south1
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=              # Google AI Studio key (keep out of chat/git)

# BigQuery
BQ_DATASET=constituency

# Firestore
FIRESTORE_COLLECTION=submissions

# Google Maps Platform (frontend)
MAPS_API_KEY=

# Telegram bot
TELEGRAM_BOT_TOKEN=

# Indian Govt Open Data (register for keys)
DATA_GOV_IN_API_KEY=          # https://data.gov.in/apis
APISETU_API_KEY=              # https://directory.apisetu.gov.in
NEGD_OPEN_API_KEY=            # https://negd.gov.in/open-api

# Kaggle (datasets) — put the REGENERATED token here, never in chat/git
KAGGLE_API_TOKEN=             # https://www.kaggle.com/settings  (Expire old, create new)
